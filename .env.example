# Copy this file to .env and fill in your own values

# JWT secret for legacy validation (kept for compatibility)
JWT_SECRET="your-jwt-secret-here"

# Supabase PostgreSQL - Connection Pooler (Transaction Mode) - for app runtime
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-x-xx-xxxx-x.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL - Connection Pooler (Session Mode) - for Prisma migrations
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-x-xx-xxxx-x.pooler.supabase.com:5432/postgres"

# Supabase project credentials (from Project Settings > API)
VITE_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_..."
